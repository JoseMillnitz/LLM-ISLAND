HISTORICAL-DECISIONS:
  - id: HD-001
    decision:  canvas chosen over DOM elements for cell rendering
    reason:    DOM caused reflow jank on mobile at puzzle sizes above 6x6
    date:      2024-01-05
    outcome:   stable for entire project lifespan
    evidence:  git:b2e1a09

  - id: HD-002
    decision:  cell size calculated dynamically from canvas dimensions
    reason:    fixed pixel sizes broke on non-standard DPI screens
    date:      2024-01-12
    outcome:   works correctly; regression tests cover this
    evidence:  git:d3f1c08

